#!/bin/bash
# Network recovery script generated by Ansible

nmcli con add type ethernet con-name {{ ansible_default_ipv4.interface }} ifname {{ ansible_default_ipv4.interface }}
nmcli c modify {{ ansible_default_ipv4.interface }} ipv4.addresses {{ ansible_default_ipv4.address }}/{{ ansible_default_ipv4.prefix }}
nmcli c modify {{ ansible_default_ipv4.interface }} ipv4.gateway {{ ansible_default_ipv4.gateway }}
nmcli c modify {{ ansible_default_ipv4.interface }} ipv4.dns "{{ ansible_dns.nameservers | join(' ') }}"
nmcli c modify {{ ansible_default_ipv4.interface }} ipv4.method manual
nmcli c modify {{ ansible_default_ipv4.interface }} connection.autoconnect yes
nmcli c down {{ ansible_default_ipv4.interface }}
nmcli c up {{ ansible_default_ipv4.interface }}
