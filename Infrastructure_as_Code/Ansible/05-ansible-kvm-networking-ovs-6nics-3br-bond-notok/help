# ansible all -m ping
ANSIBLE_CONFIG=ansible.cfg ansible all -i inventories/production/hosts.yml -m ping -u sysadmin

# Syntax check:
ANSIBLE_CONFIG=ansible.cfg ansible-playbook playbooks/ovs-network.yml --syntax-check

# Dry run:
ANSIBLE_CONFIG=ansible.cfg ansible-playbook playbooks/ovs-network.yml --check  -u sysadmin --ask-become-pass

# Run deployment:
ANSIBLE_CONFIG=ansible.cfg ansible-playbook -i inventories/production/hosts.yml playbooks/ovs-network.yml -u sysadmin --ask-become-pass



# Create the OVS Bridge
nmcli con add type ovs-bridge conn.interface br0 con-name br0

# Add Internal Bridge Interface
ip link set ens160 mtu 1500
ip link set ens193 mtu 1500

nmcli con add type ovs-port conn.interface ovs-port-br0 master br0 con-name ovs-port-br0
nmcli con add type ovs-interface slave-type ovs-port conn.interface br0 master ovs-port-br0 con-name ovs-if-br0 ipv4.method manual ipv4.addresses "192.168.178.41/24" mtu 1500

# Create Bond Port and VLAN Trunk
nmcli con add type ovs-port conn.interface br0bond0 master br0 con-name ovs-port-br0bond0

# Add Physical Interfaces as Bond Slaves
nmcli con add type ethernet conn.interface ens160 master ovs-port-br0bond0 con-name ovs-br0-if-ens160 mtu 1500
nmcli con add type ethernet conn.interface ens193 master ovs-port-br0bond0 con-name ovs-br0-if-ens193 mtu 1500

# ACTIVE_BACKUP
nmcli con modify "ovs-port-br0bond0" ovs-port.bond-mode active-backup

# BALANCE_SLB
#nmcli con modify "ovs-port-br0bond0" ovs-port.bond-mode balance-slb

# LACP
#nmcli con modify "ovs-port-br0bond0" ovs-port.bond-mode balance-tcp
#nmcli con modify "ovs-port-br0bond0" ovs-port.lacp active

# Activate All Connections
nmcli con reload
nmcli con up "ovs-port-br0bond0"
nmcli con up "ovs-br0-if-ens160"
nmcli con up "ovs-br0-if-ens193"
nmcli con up "ovs-port-br0"
nmcli con up "ovs-if-br0"

# Set only Primary Interface for Active_BACKUP Mode if selected
ovs-vsctl set port "br0bond0" other_config:bond-primary=ens160 
ovs-vsctl set port "br0bond0" other_config:bond-detect-mode=miimon
ovs-vsctl set port "br0bond0" other_config:bond-miimon-interval=100


# Set only link monitoring for BALANCE_SLB
#ovs-vsctl set port "br0bond0" other_config:bond-detect-mode=miimon
#ovs-vsctl set port "br0bond0" other_config:bond-miimon-interval=100

# Configure bond for LACP and Transmit hash policy: layer3+4
# Configure bond for LACP
#ovs-vsctl set port "br0bond0" other_config:lacp-time=fast
# Transmit hash policy: layer3+4
#ovs-vsctl set port "br0bond0" other_config:bond-hash-policy=layer3+4


