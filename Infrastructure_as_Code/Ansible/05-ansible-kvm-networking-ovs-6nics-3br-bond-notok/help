## Check OVS topology:

ovs-vsctl show
ovs-appctl bond/show br0bond0
ovs-vsctl  list port  br0bond0
#ovs-appctl lacp/show br0bond0

## Check interface IPs:

nmcli -t -f NAME,DEVICE connection show
ip a show br0
ip a show br0-vlan151
ip a show br0-vlan152
ip a show br0-vlan153
ip route

## Ping VLAN peers:

ping -c3 -I "$VLAN151" "$PING_VLAN151"
ping -c3 -I "$VLAN152" "$PING_VLAN152"
ping -c3 -I "$VLAN153" "$PING_VLAN153"

## Check LLDP Neighbors

lldpcli show neighbors ports "${IFACE3}" || echo "No LLDP neighbor on ${IFACE3}"
lldpcli show neighbors ports "${IFACE4}" || echo "No LLDP neighbor on ${IFACE4}"


# delete all
 nmcli con delete ovs-br0-if-ens160 ovs-br0-if-ens193 ovs-port-br0 ovs-port-br0bond0 ovs-if-br0 br0

# Recommended Troubleshooting Steps
#  Check OVS logs: This is the most critical step to see why the member is disabled:
journalctl -u openvswitch | grep -i "bond" | tail -n 20

# To force a failover to the other member, you can temporarily disable the active port
ovs-vsctl set port ens193 admin_state=down

# Verify the other member takes over
ovs-appctl bond/show br0bond0

# Bring it back up
ovs-vsctl set port ens193 admin_state=up
